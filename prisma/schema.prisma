generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  fullName  String? 
  major     Major?   @default(Other)
  image     String?  @default("/defaultpfp.png")
  role      Role     @default(USER)
}

enum Major {
  Computer_Science
  Business
  Biology
  Engineering
  Psychology
  English
  Other
}

enum Condition {
  excellent
  good
  fair
  poor
}

model Stuff {
  id        Int       @id @default(autoincrement())
  name      String
  quantity  Int
  condition Condition @default(good)
  owner     String
}

model Flyer {
  id          Int    @id @default(autoincrement())
  title       String
  description String
  category    String
  date        String
  location    String
  contactInfo String
  owner       String
}