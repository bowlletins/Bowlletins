generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                 Int       @id @default(autoincrement())
  email              String    @unique
  username           String    @unique
  usernameUpdatedAt  DateTime?
  password           String
  role               Role      @default(USER)
  fullName           String?
  useFullNameDisplay Boolean   @default(false)
  image              String?   @default("/defaultpfp.png")
  major              Major?    @default(Other)
}

model PasswordResetToken {
  id        Int      @id @default(autoincrement())
  email     String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Stuff {
  id        Int       @id @default(autoincrement())
  name      String
  quantity  Int
  condition Condition @default(good)
  owner     String
}

model Flyer {
  id          Int           @id @default(autoincrement())
  title       String
  description String
  date        String
  location    String
  contactInfo String
  owner       String
  category    FlyerCategory @default(Other)
  rsvpBy      String[]      @default([])
  savedBy     String[]      @default([])
  isPrivate   Boolean       @default(false)
  expiresAt   DateTime?
  flyerColor  String        @default("#fff7b3")
}

enum Role {
  USER
  ADMIN
}

enum Major {
  Computer_Science
  Business
  Biology
  Engineering
  Psychology
  English
  Other
}

enum Condition {
  excellent
  good
  fair
  poor
}

enum FlyerCategory {
  Jobs
  Internships
  Volunteer
  Events
  Academics
  Social
  Clubs_Organizations
  Other
}

model Announcement {
  id             Int      @id @default(autoincrement())
  title          String
  body           String
  createdAt      DateTime @default(now())
  authorEmail    String
  targetAudience String   @default("ALL")
}

model ContactMessage {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  subject   String
  body      String
  createdAt DateTime @default(now())
  isRead    Boolean  @default(false)
}

